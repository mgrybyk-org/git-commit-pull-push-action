{
  "name": "git-commit-pull-push-action",
  "version": "2.0.0",
  "description": "Runs git add, git commit, git pull and git push",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "ncc build index.ts --target es2024 --license licenses.txt",
    "compile": "tsc",
    "check:compile": "tsc",
    "check:lint": "eslint .",
    "checks": "run-s check:*"
  },
  "keywords": [
    "github",
    "action",
    "git",
    "add",
    "commit",
    "pull",
    "push"
  ],
  "author": "mgrybyk",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vercel/ncc": "^0.44.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3"
  }
}
